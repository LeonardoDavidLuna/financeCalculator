<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondow"
    tools:context=".MainActivity">

    <Button
        android:id="@+id/btn_cuenta"
        android:layout_width="100sp"
        android:layout_height="40sp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/shape2"
        android:onClick="Account"
        android:text="@string/btn_cuenta_string"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btn_configuracion"
        android:layout_width="160dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/shape2"
        android:onClick="Settings"
        android:text="@string/btn_configuracion_string"
        app:layout_constraintEnd_toStartOf="@+id/btn_cerrar"
        app:layout_constraintHorizontal_bias="0.666"
        app:layout_constraintStart_toEndOf="@+id/btn_cuenta"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btn_cerrar"
        android:layout_width="100sp"
        android:layout_height="40sp"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/shape2"
        android:onClick="Exit"
        android:text="@string/btn_salir_string"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/eti_Fecha"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="8dp"
        android:text="Fecha"
        android:textColor="@android:color/black"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.976"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_cerrar" />

    <TextView
        android:id="@+id/edit_usuario"
        android:layout_width="300sp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:text="Leonardo"
        android:textColor="@android:color/black"
        android:textSize="25sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.642"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/eti_Bienvenida" />

    <TextView
        android:id="@+id/eti_Bienvenida"
        android:layout_width="wrap_content"
        android:layout_height="40sp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="8dp"
        android:text="@string/txt_bienvenido_string"
        android:textColor="@android:color/black"
        android:textSize="35sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.025"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_cuenta" />

    <TextView
        android:id="@+id/eti_Saldo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginTop="24dp"
        android:text="@string/txt_saldo_actual_string"
        android:textColor="@android:color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edit_usuario" />

    <TextView
        android:id="@+id/Saldo"
        android:layout_width="110sp"
        android:layout_height="30sp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="24dp"
        android:text="0"
        android:textAlignment="textStart"
        android:textColor="@android:color/black"
        android:textSize="20sp"
        app:layout_constraintStart_toEndOf="@+id/eti_Saldo"
        app:layout_constraintTop_toBottomOf="@+id/edit_usuario" />

    <Button
        android:id="@+id/btn_Sumar"
        android:layout_width="90dp"
        android:layout_height="40dp"
        android:layout_marginTop="28dp"
        android:background="@drawable/shape2"
        android:onClick="Add"
        android:text="@string/txt_sumar_string"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/eti_periodico" />

    <EditText
        android:id="@+id/editIngresoPeriodico"
        android:layout_width="150sp"
        android:layout_height="50sp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="4dp"
        android:ems="10"
        android:inputType="numberDecimal"
        android:text="0"
        android:textColor="@android:color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@+id/eti_periodico"
        app:layout_constraintTop_toBottomOf="@+id/editIngresoEventual" />

    <EditText
        android:id="@+id/editIngresoEventual"
        android:layout_width="150sp"
        android:layout_height="50sp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="32dp"
        android:ems="10"
        android:inputType="numberDecimal"
        android:text="0"
        android:textColor="@android:color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@+id/eti_eventual"
        app:layout_constraintTop_toBottomOf="@+id/Saldo" />

    <TextView
        android:id="@+id/eti_eventual"
        android:layout_width="0dp"
        android:layout_height="40sp"
        android:layout_marginStart="44dp"
        android:layout_marginTop="44dp"
        android:text="@string/txt_ingreso_even_string"
        android:textColor="@android:color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/eti_Saldo" />

    <TextView
        android:id="@+id/eti_periodico"
        android:layout_width="0dp"
        android:layout_height="40sp"
        android:layout_marginStart="44dp"
        android:layout_marginTop="16dp"
        android:text="@string/txt_ingreso_period_string"
        android:textColor="@android:color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/eti_eventual" />

    <TextView
        android:id="@+id/eti_Gasto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:text="@string/txt_gastos_mes_string"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_Sumar" />

    <TextView
        android:id="@+id/tvSpent"
        android:layout_width="110sp"
        android:layout_height="30sp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:text="0"
        android:textColor="@color/black"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/eti_Gasto" />

    <TextView
        android:id="@+id/eti_Alerta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Alerta"
        android:textColor="@android:color/white"
        android:textSize="25sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.47"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvSpent"
        app:layout_constraintVertical_bias="0.13" />

    <Button
        android:id="@+id/btn_Gasto"
        android:layout_width="100sp"
        android:layout_height="40sp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="5dp"
        android:background="@drawable/shape2"
        android:onClick="Entry"
        android:text="@string/btn_nuevo_gasto_string"
        android:textColor="@android:color/background_light"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/eti_Alerta"
        app:layout_constraintVertical_bias="1.0" />

    <Button
        android:id="@+id/btn_Consultar"
        android:layout_width="145sp"
        android:layout_height="40sp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="5dp"
        android:background="@drawable/shape2"
        android:onClick="Consult"
        android:text="@string/btn_consul_gast_string"
        android:textColor="@android:color/background_light"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/eti_Alerta"
        app:layout_constraintVertical_bias="1.0" />

</androidx.constraintlayout.widget.ConstraintLayout>